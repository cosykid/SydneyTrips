{
  "ConnectionStrings": {
    "Trips": "Host=localhost;Port=5433;Database=trips;Username=trips;Password=trips",
    "Redis": "localhost:6379"
  },
  "Integrations": {
    "TfNsw": {
      "BaseUrl": "https://api.transport.nsw.gov.au",
      "ApiKey": ""
    },
    "Google": {
      "BaseUrl": "https://routes.googleapis.com",
      "ApiKey": ""
    }
  },
  "Auth": {
    "Issuer": "SydneyTrips",
    "Audience": "SydneyTripsClient",
    "JwtKey": "",
    "AccessTokenLifetime": "01:00:00",
    "RefreshTokenLifetime": "14.00:00:00"
  },
  "Optimisation": {
    "MaxConcurrent": 2
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*"
}
