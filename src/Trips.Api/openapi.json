  },
  "components": {
    "schemas": {
      "AddParticipantRequest": {
        "required": [
          "displayName",
          "homeAddress",
          "homeLongitude",
          "homeLatitude",
          "hasCar",
          "seats",
          "preferences"
        ],
        "type": "object",
        "properties": {
          "displayName": {
            "type": "string"
          },
          "homeAddress": {
            "type": [
              "null",
              "string"
            ]
          },
          "homeLongitude": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "null",
              "number",
              "string"
            ],
            "format": "double"
          },
          "homeLatitude": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "null",
              "number",
              "string"
            ],
            "format": "double"
          },
          "hasCar": {
            "type": "boolean"
          },
          "seats": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "preferences": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/PreferencesDto"
              }
            ]
          }
        }
      },
      "AuthTokenResponse": {
        "required": [
          "accessToken",
          "refreshToken",
          "expiresAt",
          "userId",
          "email",
          "displayName"
        ],
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "userId": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          }
        }
      },
      "CostSplitEntry": {
        "required": [
          "participantId",
          "displayName",
          "share",
          "kilometres"
        ],
        "type": "object",
        "properties": {
          "participantId": {
            "type": "string",
            "format": "uuid"
          },
          "displayName": {
            "type": "string"
          },
          "share": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "kilometres": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "CostSplitResponse": {
        "required": [
          "tripId",
          "solutionId",
          "entries",
          "totalCost",
          "todo"
        ],
        "type": "object",
        "properties": {
          "tripId": {
            "type": "string",
            "format": "uuid"
          },
          "solutionId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "entries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CostSplitEntry"
            }
          },
          "totalCost": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "todo": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "CreateTripRequest": {
        "required": [
          "name",
          "destinationName",
          "destinationLongitude",
          "destinationLatitude",
          "departAt",
          "arrivalWindowEarliest",
          "arrivalWindowLatest"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "destinationName": {
            "type": "string"
          },
          "destinationLongitude": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "destinationLatitude": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "departAt": {
            "type": "string",
            "format": "date-time"
          },
          "arrivalWindowEarliest": {
            "type": "string",
            "format": "date-time"
          },
          "arrivalWindowLatest": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "DriverRouteDto": {
        "required": [
          "id",
          "driverId",
          "travelMins",
          "orderIndex",
          "stops"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "driverId": {
            "type": "string",
            "format": "uuid"
          },
          "travelMins": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "orderIndex": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "stops": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/StopDto"
            }
          }
        }
      },
      "EnqueueRunResponse": {
        "required": [
          "runId"
        ],
        "type": "object",
        "properties": {
          "runId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "LockSolutionRequest": {
        "required": [
          "runId",
          "paretoIndex"
        ],
        "type": "object",
        "properties": {
          "runId": {
            "type": "string",
            "format": "uuid"
          },
          "paretoIndex": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "LoginRequest": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "ObjectiveWeightsDto": {
        "required": [
          "driveTime",
          "stopCount",
          "walkAndPt",
          "arrivalSpread",
          "fairness"
        ],
        "type": "object",
        "properties": {
          "driveTime": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "stopCount": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "walkAndPt": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "arrivalSpread": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "fairness": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "OptimisationRunDto": {
        "required": [
          "id",
          "tripId",
          "status",
          "solver",
          "weights",
          "startedAt",
          "completedAt",
          "failureReason",
          "bestSolutionId",
          "stats"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "tripId": {
            "type": "string",
            "format": "uuid"
          },
          "status": {
            "$ref": "#/components/schemas/OptimisationStatus"
          },
          "solver": {
            "$ref": "#/components/schemas/SolverKind"
          },
          "weights": {
            "$ref": "#/components/schemas/ObjectiveWeightsDto"
          },
          "startedAt": {
            "type": "string",
            "format": "date-time"
          },
          "completedAt": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          },
          "failureReason": {
            "type": [
              "null",
              "string"
            ]
          },
          "bestSolutionId": {
            "type": [
              "null",
              "string"
            ],
            "format": "uuid"
          },
          "stats": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/OptimisationStatsDto"
              }
            ]
          }
        }
      },
      "OptimisationRunDtoWithSolution": {
        "required": [
          "run",
          "solution"
        ],
        "type": "object",
        "properties": {
          "run": {
            "$ref": "#/components/schemas/OptimisationRunDto"
          },
          "solution": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/SolutionDto"
              }
            ]
          }
        }
      },
      "OptimisationStatsDto": {
        "required": [
          "wallClock",
          "iterationsOrNodes",
